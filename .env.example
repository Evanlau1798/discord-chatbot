# Copy this file to .env, then fill in the required secrets.
# Common integrations already have practical defaults; adjust only what differs in your environment.

# Required
DISCORD_BOT_TOKEN=
MEMORY_ENCRYPTION_KEY=

# Chat model provider: gemini, nvidia, or openai_compatible
AI_CHAT_PROVIDER=nvidia

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemma-4-31b-it
GEMINI_CACHE_ENABLED=0
GEMINI_CACHE_TTL=31536000s

# NVIDIA API Catalog or self-hosted NIM
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=google/diffusiongemma-26b-a4b-it
# NVIDIA_MESSAGE_STRATEGY options:
# - preserve: Keep system/user/assistant roles unchanged. Use this when the endpoint supports system messages.
# - user_prefix: Move all system instructions into an <application_protocol> block at the start of the first
#   user message. Use this for endpoints that only reliably accept user/assistant roles.
# The configured DiffusionGemma endpoint uses user_prefix; other NVIDIA or self-hosted NIM models may use preserve.
NVIDIA_MESSAGE_STRATEGY=user_prefix
NVIDIA_ENABLE_THINKING=1
NVIDIA_MAX_TOKENS=4096
NVIDIA_TOP_P=
NVIDIA_SEED=
NVIDIA_ASSET_MODE=nvcf
NVIDIA_INLINE_MEDIA_MAX_BYTES=184320
NVIDIA_ASSET_BASE_URL=https://api.nvcf.nvidia.com/v2/nvcf/assets

# Generic OpenAI-compatible chat completions API
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=

# Chat behavior
DEFAULT_PERSONA_KEY=example
AI_CHAT_MAX_PARALLEL_REQUESTS=3

# OpenSERP search
OPENSERP_BASE_URL=http://127.0.0.1:17000
OPENSERP_LANGUAGE=zh-TW
OPENSERP_REGION=TW
# Optional global publication-date filter. Leave blank for dynamic pages such as live weather dashboards.
# Accepts today/week/month/year or an exact OpenSERP range such as 20260701..20260720.
OPENSERP_TIME_RANGE=
OPENSERP_MAX_QUERIES_PER_TURN=3
OPENSERP_DESIRED_SOURCES=3

# Browser fallback
PATCHRIGHT_HEADLESS=1
PATCHRIGHT_BROWSER_CHANNEL=

# YouTube transcript and search
YT_DLP_BIN=yt-dlp
YTDLP_REQUEST_COOLDOWN_SECONDS=1
YOUTUBE_SEARCH_LIMIT=5
YOUTUBE_SEARCH_MAX_QUERIES_PER_TURN=1
YOUTUBE_SEARCH_QUERY_COOLDOWN_SECONDS=1
YTDLP_SEARCH_SLEEP_REQUESTS=1

# Video frame sampling
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Local OpenVINO GPU speech-to-text
# Set LOCAL_ASR_ENABLED=0 only when the local ASR service is not installed.
LOCAL_ASR_ENABLED=1
LOCAL_ASR_PORT=18765
LOCAL_ASR_MAX_CONCURRENCY=1
LOCAL_ASR_MAX_DURATION_SECONDS=60
LOCAL_ASR_MAX_QUEUE_SIZE=2
LOCAL_ASR_QUEUE_TIMEOUT_SECONDS=20
LOCAL_ASR_REQUEST_TIMEOUT_SECONDS=45
LOCAL_ASR_MAX_UPLOAD_BYTES=52428800
LOCAL_ASR_DEVICE=GPU
LOCAL_ASR_MODEL_ID=OpenVINO/whisper-small-fp16-ov
LOCAL_ASR_MODEL_REVISION=2410d022171ca8a97343182f88eec8807a324db9
LOCAL_ASR_MODEL_DIR=./tmp/openvino-asr/models/whisper-small-fp16-ov
LOCAL_ASR_CACHE_DIR=./tmp/openvino-asr/cache
LOCAL_ASR_HOTWORDS_ENABLED=0
LOCAL_ASR_MAX_HOTWORDS=8
LOCAL_ASR_READY_TIMEOUT_SECONDS=600
LOCAL_ASR_STOP_TIMEOUT_SECONDS=15

# Image understanding cache
IMAGE_CONTEXT_CACHE_TTL_HOURS=24

# Optional image generation service
# Settings are ready for the localhost API, but generation stays disabled until explicitly enabled.
AI_IMAGINE_ENABLED=0
AI_IMAGINE_RATE_LIMIT_ENABLED=1
AI_IMAGINE_DAILY_LIMIT=3
AI_IMAGINE_RATE_LIMIT_WHITELIST=
IMAGINE_QUOTA_ADMIN_USER_ID=
AI_IMAGINE_API_KEY=
AI_IMAGINE_BASE_URL=http://127.0.0.1:8890/v1
AI_IMAGINE_MODEL=gpt-image-2
AI_IMAGINE_API_MODE=local
# Keeps only recent Discord message references; image bytes are fetched only after the model requests an advertised ID.
AI_IMAGINE_REFERENCE_TTL_SECONDS=86400
AI_IMAGINE_MAX_REFERENCE_IMAGES=4

# Logging
LOG_LEVEL=INFO
