# Required
DISCORD_BOT_TOKEN=
GEMINI_API_KEY=
MEMORY_ENCRYPTION_KEY=

# Model
GEMINI_MODEL=gemma-4-31b-it
GEMINI_CACHE_ENABLED=0
GEMINI_CACHE_TTL=31536000s
DEFAULT_PERSONA_KEY=example
AI_CHAT_MAX_PARALLEL_REQUESTS=3

# Search
OPENSERP_BASE_URL=http://127.0.0.1:17000
OPENSERP_LANGUAGE=zh-TW
OPENSERP_REGION=TW
OPENSERP_TIME_RANGE=
OPENSERP_MAX_QUERIES_PER_TURN=3
OPENSERP_DESIRED_SOURCES=3

# Browser fallback
PATCHRIGHT_HEADLESS=1
PATCHRIGHT_BROWSER_CHANNEL=

# YouTube transcript reader
YT_DLP_BIN=yt-dlp
YTDLP_REQUEST_COOLDOWN_SECONDS=1
YOUTUBE_SEARCH_LIMIT=5
YOUTUBE_SEARCH_MAX_QUERIES_PER_TURN=1
YOUTUBE_SEARCH_QUERY_COOLDOWN_SECONDS=1
YTDLP_SEARCH_SLEEP_REQUESTS=1

# Video frame splitting
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Image understanding cache
IMAGE_CONTEXT_CACHE_TTL_HOURS=24

# Optional image generation service
AI_IMAGINE_ENABLED=0
AI_IMAGINE_RATE_LIMIT_ENABLED=0
AI_IMAGINE_DAILY_LIMIT=3
AI_IMAGINE_RATE_LIMIT_WHITELIST=
IMAGINE_QUOTA_ADMIN_USER_ID=
AI_IMAGINE_API_KEY=
AI_IMAGINE_BASE_URL=http://127.0.0.1:8890/v1
AI_IMAGINE_MODEL=
AI_IMAGINE_API_MODE=local

# Logging
LOG_LEVEL=INFO
