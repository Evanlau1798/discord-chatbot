# Required
DISCORD_BOT_TOKEN=
GEMINI_API_KEY=
MEMORY_ENCRYPTION_KEY=

# Model
GEMINI_MODEL=gemma-4-31b-it
GEMINI_CACHE_ENABLED=0
GEMINI_CACHE_TTL=31536000s
DEFAULT_PERSONA_KEY=example

# Discord
# Keep disabled unless your bot application has Message Content privileged intent enabled.
DISCORD_MESSAGE_CONTENT_INTENT=0

# Search
SEARXNG_BASE_URL=http://127.0.0.1:19183
SEARXNG_LANGUAGE=zh-TW
SEARXNG_ENGINES=google
SEARXNG_CATEGORIES=
SEARXNG_TIME_RANGE=

# Browser fallback
PATCHRIGHT_HEADLESS=1
PATCHRIGHT_BROWSER_CHANNEL=

# YouTube transcript reader
YT_DLP_BIN=yt-dlp

# Video frame splitting
FFMPEG_BIN=/home/evanlau/.local/bin/ffmpeg
FFPROBE_BIN=/home/evanlau/.local/bin/ffprobe

# Image understanding cache
IMAGE_CONTEXT_CACHE_TTL_HOURS=24

# Optional image generation service
AI_IMAGINE_API_KEY=
AI_IMAGINE_BASE_URL=http://127.0.0.1:8890/v1
AI_IMAGINE_MODEL=
AI_IMAGINE_API_MODE=local

# Logging
LOG_LEVEL=INFO
